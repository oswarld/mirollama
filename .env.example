# Local-first defaults (Ollama)
# Ollama serves an OpenAI-compatible endpoint at http://localhost:11434/v1
LLM_BASE_URL=http://localhost:11434/v1
# Choose one installed Ollama model tag:
# - gpt-oss:120b
# - gpt-oss:20b
# - gemma4:31b
# - gemma4:26b
LLM_MODEL_NAME=gpt-oss:20b
# LLM_API_KEY is optional for local Ollama. If unset, the backend will use a placeholder value.
# LLM_API_KEY=ollama

# Search provider (optional)
# none: offline mode (no web search)
# searxng: self-hosted meta search engine
# zep: use Zep Cloud graph search
SEARCH_PROVIDER=none
SEARXNG_BASE_URL=
WEB_SEARCH_LANGUAGE=en-US
WEB_SEARCH_LIMIT=10

# Zep (optional)
# ZEP_API_KEY=your_zep_api_key_here
